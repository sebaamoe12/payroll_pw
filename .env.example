# Database
# Supabase pooler (transaction mode — for app queries)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase pooler (session mode — for migrations/CLI)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres"

# NextAuth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase API keys (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# One-time DB setup — set a random value, POST /api/setup-db after first deploy
SETUP_KEY=""

# Stripe (optional)
STRIPE_SECRET_KEY=""

# Resend / emails (optional)
RESEND_API_KEY=""
